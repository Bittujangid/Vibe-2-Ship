# -----------------------------------------------------------------------------
# ChronoGuard AI Configuration Template
# Copy this file to '.env' at root (or client/server specific folders) and fill in your values.
# -----------------------------------------------------------------------------

# Express Backend Port
PORT=5000

# Firebase Client SDK Credentials (Prefixed with VITE_ for client availability)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here

# Gemini API Integration (To be used in the next implementation phase)
GEMINI_API_KEY=your_gemini_api_key_here
